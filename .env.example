# CyberCom frontend configuration
# Copy to .env for local/frontend runtime use.
# Keep this value aligned with backend-node/.env -> ENCRYPTION_KEY.

# Frontend dev server port
FRONTEND_PORT=5174

# Competition frontend dev server port
COMPETITION_FRONTEND_PORT=5175

# Main/admin/practice app URL
VITE_MAIN_APP_URL=http://localhost:5174

# Standalone competition app URL
VITE_COMPETITION_APP_URL=http://localhost:5175

# Backend port used by the Vite proxy
BACKEND_PORT=3000

# Opt-in local-only terminal launcher for the competition client
VITE_ENABLE_LOCAL_TERMINAL_LAUNCH=false

VITE_ENCRYPTION_KEY_HEX=replace-with-the-same-64-character-hex-key-used-by-the-backend
