# CyberCom Backend Configuration
# IMPORTANT: Copy to .env and update with REAL values - NEVER commit .env with real secrets!

# Server Configuration
PORT=3000
NODE_ENV=development
BACKEND_PORT=3000

# Database Configuration - USE STRONG, UNIQUE PASSWORD IN .env
DB_HOST=localhost
DB_PORT=3306
DB_USER=cybercom_user
DB_PASSWORD=change-this-to-a-strong-password-in-production
DB_NAME=cybercom_db

# Frontend Configuration (for CORS)
FRONTEND_URL=http://localhost:5173

# CORS Configuration (RESTRICT IN PRODUCTION)
CORS_ORIGIN=http://localhost:5173

# JWT Security Configuration
# Generate JWT_SECRET with: openssl rand -hex 32 (32 bytes minimum)
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters-change-this
JWT_EXPIRY=1h
JWT_REFRESH_SECRET=your-refresh-token-secret-also-32-chars-minimum

# Encryption Configuration (AES-256)
# Generate ENCRYPTION_KEY with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your-32-byte-hex-string-for-aes-256-encryption-change-this-value
ENCRYPTION_ALGORITHM=aes-256-cbc

# Rate Limiting Configuration
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=5

# Logging Level
LOG_LEVEL=info

# ============ CRITICAL SECURITY NOTES ============
# 1. NEVER commit actual .env file with real values to version control
# 2. Ensure .env is listed in .gitignore
# 3. Generate strong random values for all *_SECRET and *_KEY fields
# 4. Use minimum 32 character hex strings for secrets (openssl rand -hex 32)
# 5. Update DB_PASSWORD to a strong, unique password
# 6. In production:
#    - Set NODE_ENV=production
#    - Use HTTPS with valid SSL certificates
#    - Restrict CORS_ORIGIN to actual frontend domain
#    - Use managed database with encrypted connections
#    - Implement secrets management (AWS Secrets Manager, HashiCorp Vault, etc.)
#    - Rotate secrets regularly
#    - Use environment-specific secrets
# 7. Never use default or weak passwords
# ================================================
JWT_SECRET=your_jwt_secret_key_here_change_this_in_production
JWT_EXPIRES_IN=7d

# Admin API Token (required for admin endpoints)
ADMIN_TOKEN=admin-secret-token-change-this

# Session Configuration
SESSION_SECRET=session-secret-change-this-in-production

# Email Configuration (optional, if using nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Logging
LOG_LEVEL=info

# Frontend URL (for redirect and CORS)
FRONTEND_URL=http://localhost:5173
